---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="mt-auto border-t border-base-300 bg-base-200">
  <div class="mx-auto flex max-w-6xl flex-col gap-4 px-4 py-8 text-sm text-base-content/80 sm:flex-row sm:items-center sm:justify-between">
    <p>
      <span class="font-medium text-base-content">fetchurl</span>
      — content-addressable URL caching for CI and package managers.
    </p>
    <nav class="flex flex-wrap gap-4" aria-label="Footer">
      <a class="link link-hover" href={`${base}docs/`}>Docs</a>
      <a class="link link-hover" href="https://github.com/fetchurl/spec" target="_blank" rel="noopener noreferrer">Spec</a>
      <a class="link link-hover" href={`${base}llms.txt`}>llms.txt</a>
      <a class="link link-hover" href="https://github.com/fetchurl" target="_blank" rel="noopener noreferrer">GitHub</a>
    </nav>
  </div>
  <div class="border-t border-base-300">
    <p class="mx-auto max-w-6xl px-4 py-3 text-xs text-base-content/60">
      © {year} fetchurl · MIT · Site source on
      <a class="link link-hover" href="https://github.com/fetchurl/fetchurl.github.io" target="_blank" rel="noopener noreferrer">fetchurl/fetchurl.github.io</a>
    </p>
  </div>
</footer>
